---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import SkillsGrid from '../components/SkillsGrid.astro';
import Apps from '../components/Apps.astro';
import Marquee from '../components/Marquee.astro';
import Footer from '../components/Footer.astro';
---
<Base>
  <div class="glow-field"></div>
  <Nav />
  <main>
    <Hero />
    <!-- Scrolls up over the sticky hero, so it must be opaque. It carries its
         own glow, since the fixed .glow-field sits behind it. -->
    <div class="page-body">
      <SkillsGrid />
      <Apps />
      <Marquee />
    </div>
  </main>
  <Footer />
</Base>
