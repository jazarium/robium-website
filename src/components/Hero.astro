---
import AgentTabs from './AgentTabs.astro';
---
<section class="hero">
  <div class="container hero-stack">
    <div class="hero-copy">
      <h1>The Physical AI skills <span class="gradient-text">AI agents need</span>.</h1>
      <p class="sub">
        Robium gives AI agents the expertise to architect, build, and validate
        Physical AI applications across simulation, data, visualization, and
        robotics integration. Grounded in battle-tested reference applications
        and continuously evolving skills.
      </p>
    </div>
    <AgentTabs />
  </div>
</section>

<style>
  /* Fills the screen, then stays pinned while .page-body scrolls up over it
     (that layer is opaque and sits at a higher z-index — see theme.css). */
  .hero {
    position: sticky; top: 0; z-index: 0;
    min-height: 100svh;
    display: grid; align-items: center;
    padding: 88px 0 48px;
  }
  .hero-stack { display: grid; gap: 48px; width: 100%; }
  .hero-copy { text-align: center; max-width: 960px; margin: 0 auto; }
  .hero-copy h1 { text-wrap: balance; }
  .sub { color: var(--text2); margin: 24px auto 0; max-width: 44em; text-wrap: pretty; }
  .hero-stack > :global(.tabs) { width: 100%; min-width: 0; }

  /* As the next section rises over it, the hero drifts up, scales back and
     fades — a parallax hand-off rather than a hard cut. Scroll-driven CSS. */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .hero-stack {
        animation: hero-recede linear both;
        animation-timeline: view();
        animation-range: exit 0% exit 100%;
      }
      @keyframes hero-recede {
        to { opacity: 0; transform: translateY(-64px) scale(0.94); }
      }
    }
  }
</style>
